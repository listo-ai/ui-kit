{
  "name": "@listo/ui-kit",
  "version": "0.1.0",
  "description": "Shadcn UI primitives + design tokens for the listo platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./main.css": "./src/main.css"
  },
  "files": ["dist", "src/main.css"],
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0",
    "radix-ui": "^1.4.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.4.0"
  }
}
